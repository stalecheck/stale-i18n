{
  "name": "@stale-i18n/i18next",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root ../.. --project i18next",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stale-i18n/core": "workspace:*",
    "oxc-parser": "catalog:"
  },
  "devDependencies": {
    "i18next": "26.3.1"
  },
  "peerDependencies": {
    "i18next": ">=23"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
