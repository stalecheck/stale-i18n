{
  "name": "@stale-i18n/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "stale-i18n": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root ../.. --project cli",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stale-i18n/core": "workspace:*",
    "@stale-i18n/i18next": "workspace:*"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
