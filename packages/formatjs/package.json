{
  "name": "@stale-i18n/formatjs",
  "version": "0.0.0",
  "description": "FormatJS integration for stale i18n checks.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root ../.. --project formatjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stale-i18n/core": "workspace:*"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
